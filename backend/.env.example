# ========================================================================
# AI Reader — backend environment
# Copy this file to `.env` and fill in values. DO NOT commit `.env`.
# ========================================================================

# --- App ---
APP_NAME=AI Reader
# A strong random string (used to sign JWT). REQUIRED in production.
SECRET_KEY=replace-with-a-strong-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=60
DATABASE_URL=sqlite:///./app.db
UPLOAD_DIR=./uploads
CORS_ORIGINS=http://localhost:5173
# Set to `true` ONLY for local dev (skips some startup security checks).
ALLOW_INSECURE_DEV=true

# --- LLM gateway (REQUIRED) ---
# Must point at an OpenAI-SDK-compatible endpoint.
# Examples:
#   OpenAI:        https://api.openai.com/v1
#   DeepSeek:      https://api.deepseek.com
#   Your own proxy / gateway: https://api.your-gateway.com/v1
LLM_BASE_URL=
LLM_API_KEY=
LLM_PROVIDER=openai-compat
LLM_DEFAULT_MODEL=deepseek-v3.2
# Comma-separated whitelist exposed to the frontend model selector.
LLM_MODEL_LIST=deepseek-v3.2,doubao-seed-1-6-flash-250828,qwen3.5-plus
LLM_TIMEOUT_SEC=45

# --- MinerU (PDF parsing) ---
MINERU_CMD=mineru
MINERU_OUTPUT_DIR=./mineru_output
AUTO_PROCESS_ON_UPLOAD=false
# Legacy chunk sizes (used only when CHUNK_STRATEGY=recursive)
CHUNK_SIZE=700
CHUNK_OVERLAP=120
MINERU_PARSE_MODE=api_file
MINERU_API_BASE_URL=https://mineru.net/api/v1/agent
MINERU_API_TIMEOUT_SEC=300
MINERU_API_POLL_INTERVAL_SEC=3
MINERU_LANGUAGE=ch
MINERU_ENABLE_TABLE=false
MINERU_ENABLE_FORMULA=true
MINERU_IS_OCR=false
MINERU_LOADER_MODE=flash

# --- Embeddings ---
EMBEDDINGS_MODEL_NAME=all-MiniLM-L6-v2
EMBEDDINGS_DEVICE=cpu
# Chinese mirror for HF downloads (leave default if you can reach huggingface.co directly).
HF_ENDPOINT=https://hf-mirror.com

# --- Retrieval ---
# dense | bm25 | hybrid
RETRIEVAL_MODE=hybrid
RETRIEVAL_RECALL_TOPN=30
# Optional cross-encoder reranker (loads on first use). Leave empty to disable.
# e.g. BAAI/bge-reranker-base
RERANKER_MODEL=

# --- Chunking (structured, default) ---
# structured | recursive
CHUNK_STRATEGY=structured
CHILD_MAX_TOKENS=220
CHILD_OVERLAP_TOKENS=40
PARENT_MAX_TOKENS=900
